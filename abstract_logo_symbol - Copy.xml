<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 120" width="100%" height="100%">
  <!-- Definitions for reusable elements and styles -->
  <defs>
    <style>
      .trace {
        stroke: #00E5A0;
        stroke-width: 5.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        fill: none;
      }
      .via-outer {
        fill: #0A0E14;
        stroke: #00E5A0;
        stroke-width: 3.5;
      }
      .via-inner {
        fill: #00E5A0;
      }
    </style>
  </defs>

  <!-- Ground Layer Background (Optional, kept transparent for versatility) -->
  <rect width="100%" height="100%" fill="none" />

  <!-- PCB Trace Routing Paths (Conforming to strict 135° / 45° bends) -->
  <g id="traces">
    <!-- Trace 1 (Leftmost): via(24,30) -> straight down -> 45° bend down-right -> straight down -> via(44,90) -->
    <path class="trace" d="M 24 30 L 24 52 L 44 72 L 44 90" />
    
    <!-- Trace 2 (Middle): via(44,18) -> straight down -> 45° bend down-right -> straight down -->
    <path class="trace" d="M 44 18 L 44 52 L 54 62 L 54 74" />
    
    <!-- Trace 3 (Rightmost): via(64,30) -> straight down -> via(64,52) -->
    <path class="trace" d="M 64 30 L 64 52" />
  </g>

  <!-- Concentric Circular Vias (Nodes) -->
  <g id="vias">
    <!-- Via 1: Top-Left (24, 30) -->
    <g transform="translate(24, 30)">
      <circle class="via-outer" r="8" />
      <circle class="via-inner" r="3" />
    </g>

    <!-- Via 2: Top-Center (44, 18) -->
    <g transform="translate(44, 18)">
      <circle class="via-outer" r="8" />
      <circle class="via-inner" r="3" />
    </g>

    <!-- Via 3: Top-Right (64, 30) -->
    <g transform="translate(64, 30)">
      <circle class="via-outer" r="8" />
      <circle class="via-inner" r="3" />
    </g>

    <!-- Via 4: Middle-Right (64, 52) -->
    <g transform="translate(64, 52)">
      <circle class="via-outer" r="8" />
      <circle class="via-inner" r="3" />
    </g>

    <!-- Via 5: Bottom-Center (44, 90) -->
    <g transform="translate(44, 90)">
      <circle class="via-outer" r="8" />
      <circle class="via-inner" r="3" />
    </g>
  </g>
</svg>